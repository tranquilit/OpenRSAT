msgid "Zone Type"
msgstr "Typ strefy"

#: uvisnewzonewizard.lrj:$.strings.[8].value
msgctxt "tvisnewzonewizard.label6.caption"
msgid "The DNS server supports various types of zones and storage."
msgstr "Serwer DNS obsługuje różne typy stref i magazynów."

#: uvisnewzonewizard.lrj:$.strings.[9].value
